NODE_ENV=development
PORT=4000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=12h
JWT_ISSUER=scan-to-survive
JWT_AUDIENCE=scan-to-survive-clients
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash
CORS_ORIGIN=http://localhost:5173
WS_BROADCAST_INTERVAL_MS=2000
DEFAULT_TRAP_PENALTY_SECONDS=180
DEFAULT_HINT_PENALTY_SECONDS=300
